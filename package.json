{
  "name": "sc-site",
  "private": true,
  "version": "0.0.0",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun --filter '@sc-site/web' dev",
    "build": "bun --filter '@sc-site/web' build",
    "start": "bun --filter '@sc-site/web' start",
    "check": "biome check .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "typecheck": "bun --filter '*' typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "jiti": "^2.6.1",
    "typescript": "5.7.2"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
