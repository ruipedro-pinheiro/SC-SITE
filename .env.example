# sc-site env template — copy to .env.local in apps/web/.

# When the site is exposed publicly, force placeholder ship meshes and refuse
# to serve any extracted GLB files (MOCKUP.md §10 IP/hosting policy).
PUBLIC_DEPLOY=0

# Hono API base URL. `API_BASE_URL` is read server-side only (used by Next.js
# server components — both the API and web dev servers run on the Pi so
# localhost is correct). `NEXT_PUBLIC_API_BASE_URL` is exposed to the browser
# for any future client-component calls.
API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
